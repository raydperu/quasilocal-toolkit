#ifndef QLT_CONFIG_H
#define QLT_CONFIG_H

// Version information
#define QLT_VERSION_MAJOR @QuasiLocalToolkit_VERSION_MAJOR@
#define QLT_VERSION_MINOR @QuasiLocalToolkit_VERSION_MINOR@
#define QLT_VERSION_PATCH @QuasiLocalToolkit_VERSION_PATCH@
#define QLT_VERSION "@QuasiLocalToolkit_VERSION@"

// Feature definitions
#cmakedefine HAVE_HDF5

// Build type
#cmakedefine DEBUG_BUILD

// Compiler information
#define QLT_COMPILER "@CMAKE_CXX_COMPILER_ID@"
#define QLT_COMPILER_VERSION "@CMAKE_CXX_COMPILER_VERSION@"

// Platform information
#define QLT_PLATFORM "@CMAKE_SYSTEM_NAME@"
#define QLT_PROCESSOR "@CMAKE_SYSTEM_PROCESSOR@"

#endif // QLT_CONFIG_H